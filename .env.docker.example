GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

VECTOR_DB_DIR=/app/vectorstore
DOCS_DIR=/app/data/docs

TOP_K=4

MIN_RELEVANCE_SCORE=0.2

CONFIDENCE_HIGH_THRESHOLD=0.45
CONFIDENCE_MEDIUM_THRESHOLD=0.15

MEMORY_TURNS=6

SUPPORT_EMAIL=support@example.com

SYSTEM_PROMPT=You are a support assistant. Answer only using retrieved context.

ANALYTICS_DB_PATH=/app/data/analytics.db

ENABLE_DEBUG_INSPECTOR=true